#!/usr/bin/env bash
# Mock pi CLI for testing tk-loop.sh
# See MOCK_CONTRACT.md for behavior contract

set -euo pipefail

# Mock pi that succeeds or fails based on ticket ID pattern
# Usage: pi "/tk-implement <TICKET-ID> --<MODE>"
#
# Behavior Contract:
# - Ticket IDs containing "FAIL" (case insensitive) → exit 1
# - All other ticket IDs → exit 0
# - Mode MUST be one of: clarify, hands-free, dispatch, interactive
# - Missing or invalid mode → exit 1
# - Respects mode flags: --clarify, --hands-free, --dispatch, --interactive
# - Outputs to stderr in verbose mode (TK_MOCK_VERBOSE=1)

TK_MOCK_VERBOSE="${TK_MOCK_VERBOSE:-0}"

cmd="${*:-}"

# Extract ticket ID from command using pattern matching
# Format: pi "/tk-implement <ID> --<MODE>"
if [[ "$cmd" =~ /tk-implement[[:space:]]+([A-Za-z0-9-]+) ]]; then
    ticket_id="${BASH_REMATCH[1]}"
    
    # Check for mode flag - MODE IS REQUIRED
    mode=""
    if [[ "$cmd" =~ --(clarify|hands-free|dispatch|interactive) ]]; then
        mode="${BASH_REMATCH[1]}"
    else
        # No valid mode flag found - enforce mode contract
        echo "Mock pi: ERROR - Missing or invalid mode flag. Must be one of: --clarify, --hands-free, --dispatch, --interactive" >&2
        exit 1
    fi
    
    # Verbose logging
    if [[ "$TK_MOCK_VERBOSE" == "1" ]]; then
        echo "Mock pi: Processing ticket=$ticket_id mode=$mode" >&2
    fi
    
    # Check for failure pattern (case insensitive)
    if [[ "${ticket_id^^}" == *"FAIL"* ]]; then
        [[ "$TK_MOCK_VERBOSE" == "1" ]] && echo "Mock pi: Simulating failure for $ticket_id" >&2
        exit 1
    fi
    
    [[ "$TK_MOCK_VERBOSE" == "1" ]] && echo "Mock pi: Simulating success for $ticket_id" >&2
    exit 0
    
elif [[ -z "$cmd" ]]; then
    echo "Mock pi: No command provided" >&2
    exit 1
else
    echo "Mock pi: Could not parse ticket ID from: $cmd" >&2
    exit 1
fi
